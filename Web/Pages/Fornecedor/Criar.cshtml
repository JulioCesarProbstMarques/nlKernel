@page
@model nIKernel.Pages.Fornecedor.CriarModel
<h3>Cadastrar Fornecedor</h3>
<form method="post">
    <div class="form-group">
        <label asp-for="Fornecedor.NomeFantasia"></label>
        <input asp-for="Fornecedor.NomeFantasia" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Fornecedor.Cnpj"></label>
        <input asp-for="Fornecedor.Cnpj" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Fornecedor.EnderecoCompleto"></label>
        <textarea asp-for="Fornecedor.EnderecoCompleto" class="form-control"></textarea>
    </div>
    <button type="submit" class="btn btn-success">Salvar</button>
</form>